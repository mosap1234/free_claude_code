            "type": "object",
            "properties": {
              "descripcion": {"type": "string"},
              "categoria": {
                "type": "string",
                "enum": ["colores", "posicionamiento", "estilos", "funciones", "anotaciones", "otro"]
              },
              "solucion": {"type": "string"},
              "iteraciones_requeridas": {"type": "integer"}
            }
          }
        }
      }
    },
    "r": {
      "type": "object",
      "properties": {
        "aplicar_de_tikz": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "leccion": {"type": "string"},
              "aplicacion": {"type": "string"},
              "resultado": {
                "type": "string",
                "enum": ["exitoso", "parcial", "no_aplicable"]
