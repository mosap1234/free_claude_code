# Telepub Voyage (OpenAI-compatible chat at voyage.prod.telepub.cn/voyage/api/chat/completions)
# Required: API key for authentication
TELEPUB_VOYAGE_API_KEY="sk-your-api-key-here"
# OpenAI client root only — do not append /chat/completions (the SDK adds it).
TELEPUB_VOYAGE_BASE_URL="https://voyage.prod.telepub.cn/voyage/api"
# Comma-separated upstream model ids (list every id you use in MODEL / MODEL_OPUS / …).
# Merged with GET /models when present. Required for startup validation if /models is absent or empty.
TELEPUB_VOYAGE_MODELS="DeepSeek-V4-Pro,DeepSeek-V4-flash,Kimi-k2.6"


# All Claude model requests are mapped to these models, plain model is fallback
# Format: provider_type/model/name  (e.g. "telepub_voyage/DeepSeek-V4-Pro")
# MODEL_* are optional. Leave blank to inherit MODEL for that tier.
MODEL="telepub_voyage/DeepSeek-V4-flash"
MODEL_OPUS="telepub_voyage/DeepSeek-V4-Pro"
MODEL_SONNET="telepub_voyage/DeepSeek-V4-flash"
MODEL_HAIKU="telepub_voyage/Kimi-k2.6"


# Optional: enable gateway model discovery for Claude Code CLI
# CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1

# Optional: server port (default varies)
PORT=8082

# Optional: server API key for auth (Anthropic-style)
ANTHROPIC_AUTH_TOKEN="your-auth-token"